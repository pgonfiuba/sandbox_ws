<?xml version="1.0"?>
<robot name="double_pendulum" xmlns:xacro="http://www.ros.org/wiki/xacro">
  <!-- World link -->
  <link name="world"/>
  
  <!-- Link base (fijo) -->
  <link name="base_link">
      <visual>
          <origin xyz="0 0 0.02"/>
          <geometry>
              <cylinder radius="0.05" length="0.04"/>
          </geometry>
          <material name="green">
              <color rgba="0 1 0 1"/>
          </material>
      </visual>
      <collision>
          <origin xyz="0 0 0.02"/>
          <geometry>
              <cylinder radius="0.05" length="0.04"/>
          </geometry>
      </collision>
  </link>
  
  <!-- Primer eslabón -->
  <link name="link1">
      <visual>
          <origin xyz="0.1 0 0"/>
          <geometry>
              <box size="0.22 0.02 0.02"/>
          </geometry>
          <material name="blue">
              <color rgba="0 0 1 1"/>
          </material>
      </visual>
      <collision>
          <origin xyz="0.1 0 0"/>
          <geometry>
              <box size="0.2 0.02 0.02"/>
          </geometry>
      </collision>
  </link>

  <!-- Segundo eslabón -->
  <link name="link2">
      <visual>
          <origin xyz="0.1 0 0"/>
          <geometry>
              <box size="0.22 0.02 0.02"/>
          </geometry>
          <material name="red">
              <color rgba="1 0 0 1"/>
          </material>
      </visual>
      <collision>
          <origin xyz="0.1 0 0"/>
          <geometry>
              <box size="0.2 0.02 0.02"/>
          </geometry>
      </collision>
  </link>
  
  <!--******************* DEFINICIONES DE JUNTAS  *******************-->
  <!-- Junta fija entre world y base_link -->
  <joint name="fixed" type="fixed">
      <parent link="world"/>
      <child link="base_link"/>
      <origin xyz="0.2 0 0" rpy="0 0 0"/>
  </joint>
  
  <!-- Junta entre base y link1 -->
  <joint name="joint1" type="revolute">
      <parent link="base_link"/>
      <child link="link1"/>
      <origin xyz="0 0 0.05"/>
      <axis xyz="0 0 1"/>
      <limit effort="1000" lower="-3.14" upper="3.14" velocity="5"/>
  </joint>
  
  <!-- Junta entre link1 y link2 -->
  <joint name="joint2" type="revolute">
      <parent link="link1"/>
      <child link="link2"/>
      <origin xyz="0.2 0 0.02"/>
      <axis xyz="0 0 1"/>
      <limit effort="1000" lower="-3.14" upper="3.14" velocity="5"/>
  </joint>
</robot>

